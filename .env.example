# ============================================
# AiPaketim — Environment Variables
# ============================================
# Bu dosyayi .env olarak kopyala ve degerleri doldur.
# Production'da key'leri koda yazma; hosting panelindeki
# environment variables alanina ekle.

# ===== ZORUNLU (Uygulama baslatmak icin) =====

# JWT Token sifresi — production icin MUTLAKA benzersiz, uzun bir string ayarla
JWT_SECRET=

# Admin hesabi — bos birakilirsa admin hesabi olusturulmaz
ADMIN_EMAIL=admin@aipaketim.com
ADMIN_PASSWORD=
ADMIN_USERNAME=Admin

# Admin bootstrap endpoint guvenlik anahtari
ADMIN_BOOTSTRAP_SECRET=

# ===== LOGIN OTP / TRANSACTIONAL MAIL =====

# Normal e-posta/sifre girisinde 6 haneli kod dogrulamasini acmak icin true yap.
LOGIN_OTP_ENABLED=false
LOGIN_OTP_TTL_MINUTES=10

# Brevo transactional email API key. Koda yazma; hosting env alanina ekle.
BREVO_API_KEY=
BREVO_SMTP_LOGIN=
BREVO_SMTP_KEY=
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
MAIL_FROM=Froxy AI <destek@froxyai.com>

# Temp mail abuse engeli icin kayitta izin verilen e-posta domainleri.
ALLOWED_REGISTRATION_EMAIL_DOMAINS=gmail.com,googlemail.com,hotmail.com,hotmail.com.tr,outlook.com,outlook.com.tr,live.com,msn.com,yandex.com,yandex.com.tr,yandex.ru

# ===== API GATEWAY / BILLING =====

# Redis atomik bakiye, rate limit, anomaly ve opsiyonel queue icin onerilir.
REDIS_URL=

# BYOK AES-256-GCM master key. Production'da 32-byte random secret veya 64 hex karakter kullan.
GATEWAY_MASTER_KEY=

# Mevcut kredi sistemini USD gateway bakiyesine cevirmek icin varsayilan katsayi.
GATEWAY_CREDIT_USD_VALUE=0.01

# Kurumsal paketler icin varsayilan saniyelik request limiti.
GATEWAY_DEFAULT_RPS=100

# Usage event kuyruğunu BullMQ uzerinden Redis'e yazmak icin 1 yap.
BILLING_QUEUE_ENABLED=
BILLING_QUEUE_NAME=froxy-usage-events

# ===== AI PROVIDER KEYS =====

# Groq (ucretsiz modeller + fallback)
GROQ_API_KEY=

# Anthropic direct fallback/BYOK disinda platform key kullanmak icin
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# OpenRouter (300+ model katalogu)
OPENROUTER_API_KEY=

# Google Gemini (direct API)
GEMINI_API_KEYS=
GOOGLE_API_KEY=

# OpenAI GPT Image (gercek gpt-image hattı)
OPENAI_IMAGE_KEY=
OPENAI_IMAGE_KEYS=
OPENAI_IMAGE_BASE_URL=https://api.openai.com/v1
OPENAI_IMAGE_MODEL=gpt-image-2

# OpenAI-compatible chat hattı (görsel key'den ayrı tutulur)
OPENAI_CHAT_KEY=
OPENAI_CHAT_BASE_URL=https://api.openai.com/v1

# Guicore (GPT, Claude, Gemini proxy)
GUICORE_BASE_URL=https://api.guicore.com/v1
GUICORE_OPENAI_KEY=
GUICORE_GEMINI_KEY=
GUICORE_CLAUDE_KEY=
GUICORE_IMAGE_KEY=

# ===== UCRETSIZ / YAKIN-UCRETSIZ CHAT =====
CEREBRAS_API_KEY=
SAMBANOVA_API_KEY=
MISTRAL_API_KEY=
NVIDIA_API_KEY=
FIREWORKS_API_KEY=
TOGETHER_API_KEY=
XAI_API_KEY=
HF_TOKEN=
DEEPSEEK_API_KEY=

# ===== VIDEO PROVIDERS =====
FAL_API_KEY=
REPLICATE_API_TOKEN=
VIDU_API_KEY=
WAVESPEED_API_KEY=        # https://wavespeed.ai — Kling/Wan/Seedance, free trial
POLLINATIONS_KEY=         # https://enter.pollinations.ai — sk_ key, video/image için önerilir

# ===== GORSEL PROVIDERS =====
# Pollinations gen API (image models)
POLLINATIONS_API_KEY=     # https://enter.pollinations.ai - sk_ key
POLLINATIONS_API_KEYS=    # optional backup pool: sk_1,sk_2 (same account can share the same balance)
POLLINATIONS_IMAGE_MAX_CONCURRENT=1
POLLINATIONS_IMAGE_GAP_MS=4500

# Cloudflare Workers AI
CLOUDFLARE_CREDENTIALS=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# Modal cloud GPU image endpoint (PC kapaliyken calisan cloud grup)
MODAL_IMAGE_ENDPOINT=
MODAL_IMAGE_AUTH_TOKEN=
MODAL_DEFAULT_MODEL_ID=stabilityai/sdxl-turbo
MODAL_DREAMSHAPER_MODEL_ID=Lykon/dreamshaper-xl-lightning
MODAL_REALISTICVISION_MODEL_ID=SG161222/RealVisXL_V5.0_Lightning
MODAL_A1111_MODEL_ID=stabilityai/sdxl-turbo

# Runware (Flux-schnell / SDXL — ücretsiz tier)
RUNWARE_API_KEY=          # https://runware.ai

# Stability AI (Stable Image Core/Ultra — free credits)
STABILITY_API_KEY=        # https://stability.ai

# AIML API (unified: Nano Banana 2, Flux 2, GPT Image)
AIMLAPI_KEY=              # https://aimlapi.com

# ===== ARAMA SAĞLAYICILARI =====
TAVILY_API_KEY=           # https://tavily.com — 1000 req/ay ücretsiz
BRAVE_SEARCH_KEY=         # https://brave.com/search/api — 2000 req/ay ücretsiz

# ===== YENİ CHAT SAĞLAYICILARI =====
CHUTES_API_KEY=           # https://chutes.ai — 200 req/gün ücretsiz (Llama4, DeepSeek, Qwen3)
COMETAPI_KEY=             # https://cometapi.com — multi-model free key

# ===== TTS (Text-to-Speech) =====
OPENAI_TTS_KEY=

# ===== OAUTH (Opsiyonel) =====
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ===== SHOPIER ODEME OTOMASYONU (Opsiyonel) =====
# Shopier API anahtarlari varsa paket satin alma kullaniciya bagli order id ile baslar.
# Callback URL: https://froxyai-production.up.railway.app/api/shopier/callback
SHOPIER_API_KEY=
SHOPIER_API_SECRET=
SHOPIER_WEBSITE_INDEX=1
# Callback imzasina ek olarak elle test/guvenli webhook icin opsiyonel gizli deger.
SHOPIER_CALLBACK_SECRET=
# Yeni Shopier API tarafinda verilen kisisel erisim anahtari.
SHOPIER_PERSONAL_ACCESS_TOKEN=
# Webhook imzasi ayri veriliyorsa buraya ekle; bos kalirsa PAT ile dogrulama denenir.
SHOPIER_WEBHOOK_SECRET=
SHOPIER_API_BASE=https://api.shopier.com/v1

# ===== ORTAM =====
NODE_ENV=development
# PORT=3001

# ===== LOCAL PROVIDERS (ComfyUI / Fooocus / Jan / LM Studio / Ollama / Perchance proxy) =====
# Bunlar "free bize maliyeti olmayan" ve adult roadmap'te en güçlü yol.
# ComfyUI: en iyi (güçlü REST API, tamamen serbest, uncensored NSFW modellerle FULL explicit sex/porno görsel+video+sohbet mümkün)
# Fooocus: basit, kolay, çok iyi (bazı fork'larda API)
# Perchance unofficial: var ama kırılgan, önerilmez (kendi proxy endpoint'ini ver)
# Local OpenAI-comp (Jan, LM Studio, Ollama): chat için uncensored LLM'ler ile baya cinsellik destekler.
# Site: minor/real-person/rıza dışı/deepfake blokları HER YERDE kalır. Graphic/sex explicit sadece local'larda serbest (shared'larda roadmap policy: suggestive only).
# Local'da NSFW checkpoint/workflow yükle (Pony, Flux uncensored merges, video için AnimateDiff vb).

COMFYUI_API_URL=http://127.0.0.1:8188
COMFYUI_CHECKPOINT=sd_xl_base_1.0.safetensors   # veya Pony/NSFW model dosya adı
COMFYUI_WORKFLOW_JSON=   # opsiyonel: __PROMPT__ , __WIDTH__, __HEIGHT__ replace'li JSON string
COMFYUI_VIDEO_WORKFLOW_JSON=  # video için opsiyonel workflow (gifs/videos output)

FOOOCUS_API_URL=http://127.0.0.1:8888

PERCHANCE_API_URL=   # kendi Perchance-compatible proxy endpoint'in (POST {prompt, width, height})

# Jan / LM Studio / Ollama OpenAI-compatible (chat için uncensored)
JAN_API_URL=http://127.0.0.1:1337/v1
JAN_API_KEY=none
LOCAL_OPENAI_BASE_URL=http://127.0.0.1:1337/v1
LOCAL_OPENAI_API_KEY=none
LOCAL_OPENAI_MODEL=llama3.2   # veya uncensored model adın
JAN_MODEL=llama3.2
