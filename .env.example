# ============================================
# AiPaketim — Environment Variables
# ============================================
# Bu dosyayi .env olarak kopyala ve degerleri doldur.
# Production'da key'leri koda yazma; hosting panelindeki
# environment variables alanina ekle.

# ===== ZORUNLU (Uygulama baslatmak icin) =====

# JWT Token sifresi — production icin MUTLAKA benzersiz, uzun bir string ayarla
JWT_SECRET=

# Admin hesabi — bos birakilirsa admin hesabi olusturulmaz
ADMIN_EMAIL=admin@aipaketim.com
ADMIN_PASSWORD=
ADMIN_USERNAME=Admin

# Admin bootstrap endpoint guvenlik anahtari
ADMIN_BOOTSTRAP_SECRET=

# ===== LOGIN OTP / TRANSACTIONAL MAIL =====

# Normal e-posta/sifre girisinde 6 haneli kod dogrulamasini acmak icin true yap.
LOGIN_OTP_ENABLED=false
LOGIN_OTP_TTL_MINUTES=10

# Brevo transactional email API key. Koda yazma; hosting env alanina ekle.
BREVO_API_KEY=
BREVO_SMTP_LOGIN=
BREVO_SMTP_KEY=
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
MAIL_FROM=Froxy AI <destek@froxyai.com>

# ===== API GATEWAY / BILLING =====

# Redis atomik bakiye, rate limit, anomaly ve opsiyonel queue icin onerilir.
REDIS_URL=

# BYOK AES-256-GCM master key. Production'da 32-byte random secret veya 64 hex karakter kullan.
GATEWAY_MASTER_KEY=

# Mevcut kredi sistemini USD gateway bakiyesine cevirmek icin varsayilan katsayi.
GATEWAY_CREDIT_USD_VALUE=0.01

# Kurumsal paketler icin varsayilan saniyelik request limiti.
GATEWAY_DEFAULT_RPS=100

# Usage event kuyruğunu BullMQ uzerinden Redis'e yazmak icin 1 yap.
BILLING_QUEUE_ENABLED=
BILLING_QUEUE_NAME=froxy-usage-events

# ===== AI PROVIDER KEYS =====

# Groq (ucretsiz modeller + fallback)
GROQ_API_KEY=

# Anthropic direct fallback/BYOK disinda platform key kullanmak icin
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# OpenRouter (300+ model katalogu)
OPENROUTER_API_KEY=

# Google Gemini (direct API)
GEMINI_API_KEYS=
GOOGLE_API_KEY=

# Guicore (GPT, Claude, Gemini proxy)
GUICORE_BASE_URL=https://api.guicore.com/v1
GUICORE_OPENAI_KEY=
GUICORE_GEMINI_KEY=
GUICORE_CLAUDE_KEY=
GUICORE_IMAGE_KEY=

# ===== UCRETSIZ / YAKIN-UCRETSIZ CHAT =====
CEREBRAS_API_KEY=
SAMBANOVA_API_KEY=
MISTRAL_API_KEY=
NVIDIA_API_KEY=
FIREWORKS_API_KEY=
TOGETHER_API_KEY=
XAI_API_KEY=
HF_TOKEN=
DEEPSEEK_API_KEY=

# ===== VIDEO PROVIDERS =====
FAL_API_KEY=
REPLICATE_API_TOKEN=
VIDU_API_KEY=
WAVESPEED_API_KEY=        # https://wavespeed.ai — Kling/Wan/Seedance, free trial
POLLINATIONS_KEY=         # https://enter.pollinations.ai — sk_ key, video/image için önerilir

# ===== GORSEL PROVIDERS =====
# Cloudflare Workers AI
CLOUDFLARE_CREDENTIALS=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# Runware (Flux-schnell / SDXL — ücretsiz tier)
RUNWARE_API_KEY=          # https://runware.ai

# Stability AI (Stable Image Core/Ultra — free credits)
STABILITY_API_KEY=        # https://stability.ai

# AIML API (unified: Nano Banana 2, Flux 2, GPT Image)
AIMLAPI_KEY=              # https://aimlapi.com

# ===== ARAMA SAĞLAYICILARI =====
TAVILY_API_KEY=           # https://tavily.com — 1000 req/ay ücretsiz
BRAVE_SEARCH_KEY=         # https://brave.com/search/api — 2000 req/ay ücretsiz

# ===== YENİ CHAT SAĞLAYICILARI =====
CHUTES_API_KEY=           # https://chutes.ai — 200 req/gün ücretsiz (Llama4, DeepSeek, Qwen3)
COMETAPI_KEY=             # https://cometapi.com — multi-model free key

# ===== TTS (Text-to-Speech) =====
OPENAI_TTS_KEY=

# ===== OAUTH (Opsiyonel) =====
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ===== SHOPIER ODEME OTOMASYONU (Opsiyonel) =====
# Shopier API anahtarlari varsa paket satin alma kullaniciya bagli order id ile baslar.
# Callback URL: https://froxyai-production.up.railway.app/api/shopier/callback
SHOPIER_API_KEY=
SHOPIER_API_SECRET=
SHOPIER_WEBSITE_INDEX=1
# Callback imzasina ek olarak elle test/guvenli webhook icin opsiyonel gizli deger.
SHOPIER_CALLBACK_SECRET=
# Yeni Shopier API tarafinda verilen kisisel erisim anahtari.
SHOPIER_PERSONAL_ACCESS_TOKEN=
# Webhook imzasi ayri veriliyorsa buraya ekle; bos kalirsa PAT ile dogrulama denenir.
SHOPIER_WEBHOOK_SECRET=
SHOPIER_API_BASE=https://api.shopier.com/v1

# ===== ORTAM =====
NODE_ENV=development
# PORT=3001
